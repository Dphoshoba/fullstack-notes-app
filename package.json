{
  "name": "express-mongodb-auth-api",
  "version": "1.0.0",
  "description": "A full Node.js API with Express, MongoDB, JWT authentication, and protected CRUD routes.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:api": "nodemon src/server.js",
    "dev:client": "npm run dev --prefix client",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "start": "node src/server.js",
    "lint": "eslint src",
    "seed": "node src/scripts/seed.js"
  },
  "keywords": [
    "node",
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "authentication"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nanoid": "^5.0.7",
    "nodemailer": "^8.0.7",
    "openai": "^6.35.0",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "concurrently": "^9.0.1",
    "eslint": "^9.9.1",
    "nodemon": "^3.1.4"
  }
}
